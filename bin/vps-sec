#!/usr/bin/env bash
# vps-sec — toolkit de segurança para VPS (audit / harden / monitor).
# Entrypoint único. Descobre o prefixo de instalação e roteia subcomandos.
set -euo pipefail

# ── Descobre o prefixo (funciona instalado em /opt ou rodado do repo) ───────
_resolve_prefix() {
  local src="${BASH_SOURCE[0]}"
  while [[ -L "$src" ]]; do
    local dir; dir="$(cd -P "$(dirname "$src")" && pwd)"
    src="$(readlink "$src")"; [[ "$src" != /* ]] && src="$dir/$src"
  done
  cd -P "$(dirname "$src")/.." && pwd
}
VPS_SEC_PREFIX="${VPS_SEC_PREFIX:-$(_resolve_prefix)}"
export VPS_SEC_PREFIX

# shellcheck source=/dev/null
. "$VPS_SEC_PREFIX/lib/common.sh"

VERSION="$(cat "$VPS_SEC_PREFIX/VERSION" 2>/dev/null || echo "0.0.0")"

usage() {
  cat >&2 <<EOF

  ${C_CYAN}${C_BOLD}vps-sec${C_RESET} ${C_DIM}v$VERSION${C_RESET}  ${C_DIM}—${C_RESET}  🛡  segurança para VPS
  ${C_DIM}auditoria · hardening guiado · monitoramento com alertas${C_RESET}
  ${C_DIM}──────────────────────────────────────────────────────────${C_RESET}

  ${C_DIM}uso:${C_RESET} vps-sec ${C_GREEN}<comando>${C_RESET} ${C_DIM}[opções]${C_RESET}

  ${C_BOLD}${C_YELLOW}▸ Auditoria${C_RESET}
    ${C_GREEN}audit${C_RESET} ${C_DIM}[--json] [--quiet]${C_RESET}      varre a segurança (somente leitura)
    ${C_DIM}└ exit: 0 ok · 1 achados · 2 crítico${C_RESET}

  ${C_BOLD}${C_YELLOW}▸ Hardening${C_RESET}
    ${C_GREEN}harden${C_RESET} ${C_DIM}[opções]${C_RESET}             aplica correções (com backup e rollback)
       ${C_DIM}--dry-run${C_RESET}                 só mostra o que mudaria
       ${C_DIM}--yes${C_RESET}                     aplica as correções seguras
       ${C_DIM}--allow-risky${C_RESET}             habilita as correções arriscadas
       ${C_DIM}--only ID[,ID…]${C_RESET}           corrige só estes checks
       ${C_DIM}--confirm-ssh${C_RESET}             confirma a mudança de SSH
    ${C_GREEN}rollback${C_RESET} ${C_DIM}[last|<ts>|--list]${C_RESET}  restaura um backup do harden

  ${C_BOLD}${C_YELLOW}▸ Monitor & alertas${C_RESET}
    ${C_GREEN}monitor${C_RESET} ${C_DIM}<status|run|log>${C_RESET}    estado / execução / log do daemon
    ${C_GREEN}baseline update${C_RESET} ${C_DIM}[…]${C_RESET}         atualiza baselines (portas, containers…)
    ${C_GREEN}digest${C_RESET} ${C_DIM}[--now]${C_RESET}              resumo diário / heartbeat
    ${C_GREEN}test-webhook${C_RESET}                envia um evento de teste ao n8n

  ${C_BOLD}${C_YELLOW}▸ Manutenção${C_RESET}
    ${C_GREEN}self-update${C_RESET}                 atualiza a partir do repositório
    ${C_GREEN}version${C_RESET} ${C_DIM}·${C_RESET} ${C_GREEN}help${C_RESET}               versão · esta ajuda
    ${C_GREEN}uninstall${C_RESET}                   remove o vps-sec

  ${C_DIM}config:${C_RESET} $VPS_SEC_CONFIG
  ${C_DIM}repo:  ${C_RESET} https://github.com/berodcdev/vps-sec

EOF
}

cmd="${1:-help}"; shift || true
export VPS_SEC_SUBCMD="$cmd"

case "$cmd" in
  audit)
    require_root
    detect_system
    load_config
    # shellcheck source=/dev/null
    . "$VPS_SEC_MODULES/audit/run.sh"
    audit_main "$@"
    ;;

  harden)
    require_root
    detect_system
    load_config
    # shellcheck source=/dev/null
    . "$VPS_SEC_PREFIX/lib/backup.sh"
    # shellcheck source=/dev/null
    . "$VPS_SEC_MODULES/harden/fixes.sh"
    harden_main "$@"
    ;;

  _rollback-pending)
    # Chamado pelo timer transiente do systemd-run (uso interno).
    require_root
    detect_system
    load_config
    # shellcheck source=/dev/null
    . "$VPS_SEC_PREFIX/lib/backup.sh"
    rollback_pending_ssh
    ;;

  rollback)
    require_root
    detect_system
    load_config
    # shellcheck source=/dev/null
    . "$VPS_SEC_PREFIX/lib/backup.sh"
    rollback_main "$@"
    ;;

  monitor)
    require_root
    detect_system
    load_config
    # shellcheck source=/dev/null
    . "$VPS_SEC_PREFIX/lib/alert.sh"
    # shellcheck source=/dev/null
    . "$VPS_SEC_PREFIX/lib/baseline.sh"
    # shellcheck source=/dev/null
    . "$VPS_SEC_MODULES/monitor/run.sh"
    monitor_main "$@"
    ;;

  baseline)
    require_root
    detect_system
    load_config
    # shellcheck source=/dev/null
    . "$VPS_SEC_PREFIX/lib/baseline.sh"
    baseline_main "$@"
    ;;

  test-webhook)
    require_root
    detect_system
    load_config
    # shellcheck source=/dev/null
    . "$VPS_SEC_PREFIX/lib/alert.sh"
    alert_test
    ;;

  digest)
    require_root
    detect_system
    load_config
    # shellcheck source=/dev/null
    . "$VPS_SEC_PREFIX/lib/alert.sh"
    # shellcheck source=/dev/null
    . "$VPS_SEC_PREFIX/lib/baseline.sh"
    # shellcheck source=/dev/null
    . "$VPS_SEC_MODULES/monitor/digest.sh"
    digest_main "$@"
    ;;

  version|--version|-v) echo "vps-sec v$VERSION" ;;
  help|--help|-h)       usage ;;

  self-update)
    require_root
    # Lê a origem gravada na instalação.
    src="$VPS_SEC_PREFIX/.source"
    [[ -f "$src" ]] || die "origem desconhecida (.source ausente). Reinstale via install.sh --repo usuario/repo"
    # shellcheck source=/dev/null
    . "$src"
    [[ -n "${GITHUB_REPO:-}" ]] || die "GITHUB_REPO não definido em $src"
    log "Atualizando a partir de $GITHUB_REPO@${GITHUB_BRANCH:-main}..."
    # Preserva a config (o install.sh é idempotente e não sobrescreve o config).
    curl -fsSL "https://raw.githubusercontent.com/$GITHUB_REPO/${GITHUB_BRANCH:-main}/install.sh" \
      | bash -s -- --repo "$GITHUB_REPO" --branch "${GITHUB_BRANCH:-main}" \
      || die "falha ao atualizar"
    ;;

  uninstall)
    require_root
    if [[ -x "$VPS_SEC_PREFIX/uninstall.sh" ]]; then
      exec "$VPS_SEC_PREFIX/uninstall.sh" "$@"
    else
      die "uninstall.sh não encontrado em $VPS_SEC_PREFIX"
    fi
    ;;

  *)
    error "Comando desconhecido: $cmd"
    usage
    exit 64
    ;;
esac
